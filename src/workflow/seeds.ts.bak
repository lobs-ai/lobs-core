        config: { callable: "scheduler.fire_due_events" },
        on_success: "done",
        on_failure: { retry: 1 },
      },
      { id: "done", type: "cleanup", config: { delete_session: false } },
    ],
    edges: [],
    metadata: { author: "lobs", category: "system", system: true },
  },

