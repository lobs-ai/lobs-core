{
  "name": "lobs-core",
  "version": "0.1.0",
  "description": "Personal AI agent system — orchestrator, runner, context engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && chmod +x dist/cli/lobs.js && npm run copy-skills && npm run copy-python-tools",
    "copy-skills": "mkdir -p dist/skills && cp -r src/skills/* dist/skills/",
    "copy-python-tools": "cp src/runner/tools/web_fetch.py dist/runner/tools/web_fetch.py 2>/dev/null || true",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "sync-addons": "bin/sync-addons",
    "start": "node dist/main.js",
    "postinstall": "npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "better-sqlite3": "^11.0.0",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.39.0",
    "googleapis": "^171.4.0",
    "onnxruntime-node": "^1.20.0",
    "playwright": "^1.58.2",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "bin": {
    "lobs": "./dist/cli/lobs.js",
    "paw-task": "./src/cli/paw-task.ts",
    "paw-inbox": "./src/cli/paw-inbox.ts",
    "paw-status": "./src/cli/paw-status.ts"
  }
}
